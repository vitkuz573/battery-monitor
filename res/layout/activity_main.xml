<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF121212">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:background="#FF1A1A1A">

        <TextView
            android:id="@+id/battery_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#FFFFFFFF"
            android:textSize="52sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/battery_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFB0B0B0"
            android:textSize="14sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/battery_temp_voltage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF808080"
            android:textSize="12sp"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF1E1E1E">

        <LinearLayout
            android:id="@+id/tab_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <Button
                android:id="@+id/tab_battery"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Battery"
                android:textSize="12sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:backgroundTint="#FF2D2D2D"
                android:textColor="#FFFFFFFF"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tab_cpu"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="CPU"
                android:textSize="12sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:backgroundTint="#FF2D2D2D"
                android:textColor="#FFFFFFFF"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tab_network"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Network"
                android:textSize="12sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:backgroundTint="#FF2D2D2D"
                android:textColor="#FFFFFFFF"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tab_storage"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Storage"
                android:textSize="12sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:backgroundTint="#FF2D2D2D"
                android:textColor="#FFFFFFFF"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tab_system"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="System"
                android:textSize="12sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:backgroundTint="#FF2D2D2D"
                android:textColor="#FFFFFFFF"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tab_wakelocks"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Locks"
                android:textSize="12sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:backgroundTint="#FF2D2D2D"
                android:textColor="#FFFFFFFF"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FF333333" />

    <ScrollView
        android:id="@+id/content_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:id="@+id/content_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FF333333" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center"
        android:background="#FF1A1A1A">

        <Button
            android:id="@+id/btn_refresh"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Refresh"
            android:textSize="13sp"
            android:backgroundTint="#FF4FC3F7"
            android:textColor="#FF000000"
            android:stateListAnimator="@null"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <Button
            android:id="@+id/btn_service"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Monitor"
            android:textSize="13sp"
            android:backgroundTint="#FF2D2D2D"
            android:textColor="#FFFFFFFF"
            android:stateListAnimator="@null"
            android:minWidth="0dp"
            android:minHeight="0dp" />
    </LinearLayout>
</LinearLayout>
